# Gemini Live API — server-side key used only by the orchestrator to mint
# short-lived ephemeral tokens. Never expose this to the frontend.
GEMINI_API_KEY=

# Supermemory managed RAG + memory API key (server-side only).
SUPERMEMORY_API_KEY=

# Web image/video search fallback provider key (provider TBD — see
# IMPLEMENTATION_PLAN.md §7 open decisions).
WEB_IMAGE_SEARCH_API_KEY=

# Orchestrator HTTP port.
PORT=8787
