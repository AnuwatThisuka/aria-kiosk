{
  "name": "@aria/orchestrator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "start": "bun --env-file=../../.env run src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "ingest:media": "bun --env-file=../../.env run scripts/ingest-media.ts",
    "lint": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aria/media-search": "workspace:*",
    "@google/genai": "^1.0.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
